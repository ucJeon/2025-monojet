executable            = /users/ujeon/2025-monojet/MONOJET-WORKSPACE/src/Delphes/exe.sh
getenv                = True
should_transfer_files = YES
when_to_transfer_output = ON_EXIT
transfer_input_files  = /users/ujeon/2025-monojet/MONOJET-WORKSPACE/src/Delphes/toCondor

# --- wjets.1 ---
environment = "job_name=monojetDelphesStep.wjets.1 sample_name=wjets version=v1.1.0 full_target=wjets.1 input_parent=/user/ujeon/monojet/HepMC output_parent=/user/ujeon/monojet/mc main_path=/users/ujeon/2025-monojet/MONOJET-WORKSPACE/src/Delphes process_min=0 process_max=0 is_test=1"
